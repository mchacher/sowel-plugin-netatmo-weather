{
  "id": "netatmo_weather",
  "type": "integration",
  "name": "Netatmo Weather",
  "version": "2.0.0",
  "description": "Netatmo Weather Station — temperature, humidity, pressure, CO2, wind, rain",
  "icon": "CloudSun",
  "repo": "mchacher/sowel-plugin-netatmo-weather",
  "author": "mchacher",
  "sowelVersion": ">=1.2.11",
  "settings": [
    {
      "key": "client_id",
      "label": "Client ID",
      "type": "text",
      "required": true,
      "placeholder": "From dev.netatmo.com"
    },
    {
      "key": "client_secret",
      "label": "Client Secret",
      "type": "password",
      "required": true
    },
    {
      "key": "refresh_token",
      "label": "Refresh Token",
      "type": "password",
      "required": true,
      "placeholder": "With read_station scope"
    },
    {
      "key": "polling_interval",
      "label": "Polling interval (seconds)",
      "type": "number",
      "required": false,
      "defaultValue": "300",
      "placeholder": "Min 60, default 300"
    }
  ],
  "apiVersion": 2
}
